# Variables de entorno del proyecto.
# Copia este archivo a .env.local y completa los valores reales.
# .env.local nunca se sube al repositorio (ver .gitignore).

# ── Supabase (opcional) ──────────────────────────────────────────
# @supabase/supabase-js ya está instalado pero todavía NO está conectado
# en el código (los escenarios guardados solo viven en memoria del navegador).
# Completa estas variables únicamente si implementas la persistencia real:
#   1. Crea un proyecto gratuito en https://supabase.com
#   2. Copia la URL y la anon key desde Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
